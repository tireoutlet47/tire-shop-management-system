{
  "name": "tire-shop-backend",
  "version": "1.0.0",
  "description": "Backend API for Tire Shop Management System",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback",
    "db:seed": "knex seed:run",
    "db:reset": "knex migrate:rollback --all && knex migrate:latest && knex seed:run"
  },
  "keywords": [
    "tire",
    "shop",
    "management",
    "inventory",
    "invoicing",
    "mobile"
  ],
  "author": "tireoutlet47",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "pg": "^8.10.0",
    "knex": "^2.4.2",
    "objection": "^3.0.1",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "joi": "^17.9.2",
    "axios": "^1.4.0",
    "aws-sdk": "^2.1400.0",
    "twilio": "^3.81.0",
    "nodemailer": "^6.9.3",
    "socket.io": "^4.6.1",
    "redis": "^4.6.5",
    "winston": "^3.8.2",
    "express-rate-limit": "^6.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.6.1",
    "supertest": "^6.3.3",
    "eslint": "^8.45.0",
    "prettier": "^2.8.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
